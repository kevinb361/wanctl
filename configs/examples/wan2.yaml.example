# wanctl Configuration - Secondary WAN
#
# This is a template for a secondary/backup WAN connection.
# Copy to /etc/wanctl/wan2.yaml and customize for your setup.
#
# Common use cases:
# - Failover/backup connection
# - Load balancing secondary
# - Lower-priority connection for bulk traffic
#
# Usage: systemctl enable --now wanctl@wan2.service

# Schema version for config format compatibility
schema_version: "1.0"

wan_name: "wan2"

# RouterOS connection
router:
  transport: "rest"  # "rest" (recommended) or "ssh"
  host: "192.168.1.1"
  user: "admin"
  ssh_key: "/etc/wanctl/ssh/router.key"  # For SSH transport
  # REST transport settings
  password: "${ROUTER_PASSWORD}"  # From /etc/wanctl/secrets
  port: 443
  verify_ssl: false

queues:
  download: "WAN-Download-2"
  upload: "WAN-Upload-2"

continuous_monitoring:
  enabled: true

  # Adjust baseline for your secondary connection type
  baseline_rtt_initial: 30

  # Download - adjust for your secondary WAN's speed
  # Secondary WANs are often slower (DSL backup for cable, etc.)
  download:
    floor_mbps: 25
    ceiling_mbps: 100
    step_up_mbps: 2
    factor_down: 0.90

  # Upload
  upload:
    floor_mbps: 5
    ceiling_mbps: 20
    step_up_mbps: 0.5
    factor_down: 0.95

  # Thresholds - tune for your connection type
  thresholds:
    target_bloat_ms: 5
    warn_bloat_ms: 15
    baseline_time_constant_sec: 2.5
    load_time_constant_sec: 0.25

  ping_hosts: ["1.1.1.1"]
  use_median_of_three: false

# Ping source IP (optional, default: OS routing table decides)
# ping_source_ip: ""

# IRTT UDP RTT measurement (optional, disabled by default)
# irtt:
#   enabled: false
#   server: "your-irtt-server-ip"
#   port: 2112
#   duration_sec: 1.0
#   cadence_sec: 10

# Reflector quality scoring (optional)
# reflector_quality:
#   min_score: 0.8
#   probe_interval_sec: 30
#   recovery_count: 3

# OWD asymmetry detection (optional, active when IRTT provides OWD data)
# owd_asymmetry:
#   ratio_threshold: 2.0

# Dual-signal fusion (optional, requires irtt.enabled: true)
# fusion:
#   enabled: false
#   icmp_weight: 0.7
#   healing:
#     suspend_threshold: 0.3
#     recover_threshold: 0.5
#     suspend_window_sec: 60.0
#     recover_window_sec: 300.0
#     grace_period_sec: 1800.0

# Adaptive tuning (optional, disabled by default)
# Analyzes metrics history to automatically optimize control parameters.
# All changes are runtime-only -- YAML values are always the reset escape hatch.
# tuning:
#   enabled: false
#   cadence_sec: 3600         # Analyze every hour (matches maintenance window)
#   lookback_hours: 24        # How far back to query metrics
#   warmup_hours: 1           # Minimum data before first tuning
#   max_step_pct: 10          # Max 10% change per tuning cycle
#   min_confidence: 0.3       # Skip weak recommendations below this confidence
#   bounds:
#     target_bloat_ms: {min: 3, max: 30}
#     warn_bloat_ms: {min: 10, max: 100}
#     hard_red_bloat_ms: {min: 30, max: 200}
#     load_time_constant_sec: {min: 0.1, max: 10.0}
#     baseline_time_constant_sec: {min: 5.0, max: 500.0}

# Alerting (optional)
# alerting:
#   enabled: false
#   webhook_url: "${DISCORD_WEBHOOK_URL}"

# Storage retention (optional, defaults shown)
# storage:
#   maintenance_interval_seconds: 900   # Run cleanup/downsampling every 15 minutes
#   retention:
#     raw_age_seconds: 900
#     aggregate_1m_age_seconds: 86400
#     aggregate_5m_age_seconds: 604800
#     prometheus_compensated: false

logging:
  main_log: "/var/log/wanctl/wan2.log"
  debug_log: "/var/log/wanctl/wan2_debug.log"

lock_file: "/run/wanctl/wan2.lock"
lock_timeout: 300

timeouts:
  ssh_command: 15
  ping: 1

state_file: "/var/lib/wanctl/wan2_state.json"
