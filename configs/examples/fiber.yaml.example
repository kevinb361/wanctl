# wanctl Configuration - Fiber Connection (GPON/XGS-PON)
#
# Template for high-speed, low-latency fiber connections.
# Fiber is typically very stable with consistent low latency.
#
# Characteristics:
# - Low baseline RTT (5-15ms typical)
# - High bandwidth (100M-10G)
# - Very stable, minimal jitter
# - Less aggressive tuning needed

# Schema version for config format compatibility
schema_version: "1.0"

wan_name: "fiber"

# RouterOS connection
router:
  transport: "rest"  # "rest" (recommended) or "ssh"
  host: "192.168.1.1"
  user: "admin"
  ssh_key: "/etc/wanctl/ssh/router.key"  # For SSH transport
  # REST transport settings
  password: "${ROUTER_PASSWORD}"  # From /etc/wanctl/secrets
  port: 443
  verify_ssl: false

queues:
  download: "WAN-Download-Fiber"
  upload: "WAN-Upload-Fiber"

continuous_monitoring:
  enabled: true

  # Fiber typically has very low baseline RTT
  baseline_rtt_initial: 8       # milliseconds (very low for fiber)

  # Download - fiber is stable, can be less aggressive
  download:
    floor_green_mbps: 800       # High floor - fiber rarely degrades
    floor_yellow_mbps: 600
    floor_soft_red_mbps: 400
    floor_red_mbps: 200
    ceiling_mbps: 950           # Near line rate (1 Gbps plan)
    step_up_mbps: 20            # Fast recovery - fiber is stable
    factor_down: 0.90           # Less aggressive backoff needed

  # Upload - symmetrical fiber can handle more
  upload:
    floor_mbps: 100
    ceiling_mbps: 950           # Symmetrical gigabit
    step_up_mbps: 10
    factor_down: 0.90

  # Thresholds - tighter for fiber since baseline is so low
  thresholds:
    target_bloat_ms: 5          # Tighter threshold for low-latency fiber
    warn_bloat_ms: 15
    hard_red_bloat_ms: 30
    baseline_time_constant_sec: 5.0   # Very slow baseline tracking (fiber is stable)
    load_time_constant_sec: 0.33      # Moderate response

  # Single reflector is fine for stable fiber
  ping_hosts: ["1.1.1.1"]
  use_median_of_three: false    # Single ping OK for stable connections

# Ping source IP (optional, default: OS routing table decides)
# ping_source_ip: ""

# IRTT UDP RTT measurement (optional, disabled by default)
# irtt:
#   enabled: false
#   server: "your-irtt-server-ip"
#   port: 2112
#   duration_sec: 1.0
#   cadence_sec: 10

# Reflector quality scoring (optional)
# reflector_quality:
#   min_score: 0.8
#   probe_interval_sec: 30
#   recovery_count: 3

# OWD asymmetry detection (optional, active when IRTT provides OWD data)
# owd_asymmetry:
#   ratio_threshold: 2.0

# Dual-signal fusion (optional, requires irtt.enabled: true)
# fusion:
#   enabled: false
#   icmp_weight: 0.7
#   healing:
#     suspend_threshold: 0.3
#     recover_threshold: 0.5
#     suspend_window_sec: 60.0
#     recover_window_sec: 300.0
#     grace_period_sec: 1800.0

# Adaptive tuning (optional, disabled by default)
# Analyzes metrics history to automatically optimize control parameters.
# All changes are runtime-only -- YAML values are always the reset escape hatch.
# tuning:
#   enabled: false
#   cadence_sec: 3600         # Analyze every hour (matches maintenance window)
#   lookback_hours: 24        # How far back to query metrics
#   warmup_hours: 1           # Minimum data before first tuning
#   max_step_pct: 10          # Max 10% change per tuning cycle
#   min_confidence: 0.3       # Skip weak recommendations below this confidence
#   bounds:
#     target_bloat_ms: {min: 3, max: 30}
#     warn_bloat_ms: {min: 10, max: 100}
#     hard_red_bloat_ms: {min: 30, max: 200}
#     load_time_constant_sec: {min: 0.1, max: 10.0}
#     baseline_time_constant_sec: {min: 5.0, max: 500.0}

# Alerting (optional)
# alerting:
#   enabled: false
#   webhook_url: "${DISCORD_WEBHOOK_URL}"

# Storage retention (optional, defaults shown)
# storage:
#   maintenance_interval_seconds: 900   # Run cleanup/downsampling every 15 minutes
#   retention:
#     raw_age_seconds: 900
#     aggregate_1m_age_seconds: 86400
#     aggregate_5m_age_seconds: 604800
#     prometheus_compensated: false

logging:
  main_log: "/var/log/wanctl/fiber.log"
  debug_log: "/var/log/wanctl/fiber_debug.log"

lock_file: "/run/wanctl/fiber.lock"
lock_timeout: 300

timeouts:
  ssh_command: 15
  ping: 1

state_file: "/var/lib/wanctl/fiber_state.json"
