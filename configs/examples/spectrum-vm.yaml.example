# wanctl Configuration - Spectrum Cable (Linux CAKE VM)
#
# Template for Spectrum cable connection running on cake-shaper VM
# with Linux CAKE backend (not MikroTik queue trees).
#
# Characteristics:
# - Transport: linux-cake (tc subprocess on bridge member port)
# - Router section kept for steering daemon REST access
# - cake_params: download_interface and upload_interface are the same NIC
#   (CAKE creates separate download/upload qdiscs on the router-side bridge port)
# - Overhead: docsis (DOCSIS 3.0/3.1 cable)
# - No ecn in cake_params (iproute2-6.15.0 does not support keyword; CAKE enables ECN by default)

# Schema version for config format compatibility
schema_version: "1.0"

wan_name: "spectrum"

# RouterOS connection (kept for steering daemon REST access to mangle rules)
router:
  transport: "linux-cake"  # Linux CAKE backend on VM
  host: "10.10.99.1"
  user: "admin"
  ssh_key: "/etc/wanctl/ssh/router.key"
  password: "${ROUTER_PASSWORD}"
  port: 443
  verify_ssl: false

# Queue names in RouterOS (used by steering daemon for queue tree management)
queues:
  download: "WAN-Download-Spectrum"
  upload: "WAN-Upload-Spectrum"

# CAKE qdisc parameters for LinuxCakeBackend
# Both interfaces point to the same NIC -- direction handled by build_cake_params()
# adding 'ingress' for download and 'ack-filter' for upload
cake_params:
  download_interface: "ens17"    # Router-side NIC (CAKE target)
  upload_interface: "ens17"      # Same NIC
  overhead: "docsis"             # DOCSIS cable encapsulation (CAKE-05)
  memlimit: "32mb"              # Memory limit per qdisc (CAKE-06)
  rtt: "100ms"                  # Conservative default, tunable (CAKE-10)

# Continuous monitoring - tune these for your cable connection
continuous_monitoring:
  enabled: true
  baseline_rtt_initial: 24

  download:
    floor_green_mbps: 550
    floor_yellow_mbps: 350
    floor_soft_red_mbps: 275
    floor_red_mbps: 200
    ceiling_mbps: 940
    step_up_mbps: 15
    factor_down: 0.85
    factor_down_yellow: 0.92
    green_required: 3

  upload:
    floor_mbps: 8
    ceiling_mbps: 38
    step_up_mbps: 1
    factor_down: 0.85
    green_required: 3

  thresholds:
    target_bloat_ms: 12
    warn_bloat_ms: 45
    hard_red_bloat_ms: 80
    baseline_time_constant_sec: 50
    load_time_constant_sec: 0.10
    accel_threshold_ms: 12

  ping_hosts: ["1.1.1.1", "208.67.222.222", "9.9.9.9"]
  use_median_of_three: true

  fallback_checks:
    enabled: true
    check_gateway: true
    check_tcp: true
    gateway_ip: "10.10.110.1"
    tcp_targets:
      - ["1.1.1.1", 443]
      - ["208.67.222.222", 443]
    fallback_mode: "graceful_degradation"
    max_fallback_cycles: 3

state_file: "/var/lib/wanctl/spectrum_state.json"

logging:
  main_log: "/var/log/wanctl/spectrum.log"
  debug_log: "/var/log/wanctl/spectrum_debug.log"

lock_file: "/run/wanctl/spectrum.lock"
lock_timeout: 300

timeouts:
  ssh_command: 15
  ping: 0.5

irtt:
  enabled: true
  server: "104.200.21.31"
  port: 2112
  duration_ms: 1000
  packet_size: 48
  cadence_sec: 10

reflector_quality:
  min_score: 0.8
  probe_interval_sec: 30
  recovery_count: 3

fusion:
  enabled: true
  icmp_weight: 0.7

tuning:
  enabled: true
  cadence_sec: 3600
  lookback_hours: 24
  warmup_hours: 1
  max_step_pct: 10.0
  bounds:
    target_bloat_ms:
      min: 5.0
      max: 30.0
    warn_bloat_ms:
      min: 15.0
      max: 80.0
    hampel_sigma_threshold:
      min: 1.5
      max: 5.0
    hampel_window_size:
      min: 5
      max: 15
    load_time_constant_sec:
      min: 0.5
      max: 10.0
    fusion_icmp_weight:
      min: 0.5
      max: 0.95
    reflector_min_score:
      min: 0.5
      max: 0.95
    baseline_rtt_min:
      min: 5.0
      max: 30.0
    baseline_rtt_max:
      min: 25.0
      max: 100.0

alerting:
  enabled: true
  webhook_url: "${DISCORD_WEBHOOK_URL}"
