# wanctl Configuration - DOCSIS Cable Connection
#
# Template for cable modem (DOCSIS 3.0/3.1) connections.
# Cable has variable latency due to shared spectrum and DOCSIS timing.
#
# Characteristics:
# - Moderate baseline RTT (15-30ms typical)
# - Variable latency (CMTS contention, DOCSIS MAP cycles)
# - Asymmetric speeds (fast download, slower upload)
# - May require median-of-three pings for accuracy

# Schema version for config format compatibility
schema_version: "1.0"

wan_name: "cable"

# RouterOS connection
router:
  transport: "rest"  # "rest" (recommended) or "ssh"
  host: "192.168.1.1"
  user: "admin"
  ssh_key: "/etc/wanctl/ssh/router.key"  # For SSH transport
  # REST transport settings
  password: "${ROUTER_PASSWORD}"  # From /etc/wanctl/secrets
  port: 443
  verify_ssl: false

queues:
  download: "WAN-Download-Cable"
  upload: "WAN-Upload-Cable"

continuous_monitoring:
  enabled: true

  # Cable typically has ~24-30ms baseline RTT
  baseline_rtt_initial: 24      # DOCSIS adds latency vs fiber

  # Download - cable can vary significantly
  # Use 4-state with SOFT_RED for handling RTT-only spikes
  download:
    floor_green_mbps: 550       # High floor when CMTS is quiet
    floor_yellow_mbps: 350      # Moderate floor for early warning
    floor_soft_red_mbps: 275    # SOFT_RED handles RTT spikes without steering
    floor_red_mbps: 200         # Emergency floor
    ceiling_mbps: 940           # Near plan speed (1 Gbps nominal)
    step_up_mbps: 15            # Fast ramp (validated over 10 via RRUL A/B)
    factor_down: 0.90           # 10% RED backoff (validated over 0.85)
    factor_down_yellow: 0.92    # 8% YELLOW decay (validated: 0.97 doubles latency)
    green_required: 5           # Conservative recovery (validated over 3)

  # Upload - cable upload is typically 1:10 or 1:20 of download
  upload:
    floor_mbps: 8               # Keep upstream functional
    ceiling_mbps: 38            # Typical 40 Mbps plan with overhead
    step_up_mbps: 1             # Gentle climb
    factor_down: 0.90           # Less aggressive backoff
    green_required: 5           # Match download (validated independently)

  # Thresholds - tuned for DOCSIS latency characteristics
  thresholds:
    target_bloat_ms: 9          # GREEN -> YELLOW (validated: safe with dwell_cycles=5)
    warn_bloat_ms: 45           # YELLOW -> SOFT_RED
    hard_red_bloat_ms: 60       # SOFT_RED -> RED (validated: faster floor clamp)
    dwell_cycles: 5             # Hysteresis: 250ms gate filters DOCSIS jitter (validated over 3)
    deadband_ms: 3.0            # Hysteresis: 3ms split threshold (validated: 5.0 is worse)
    # EWMA time constants (interval-independent)
    baseline_time_constant_sec: 50   # Slow EWMA for stable baseline
    load_time_constant_sec: 0.10     # Fast EWMA for load RTT (100ms)
    accel_threshold_ms: 12           # RTT spike threshold for instant RED

  # Median-of-three helps with DOCSIS reflector variation
  ping_hosts: ["1.1.1.1", "8.8.8.8", "9.9.9.9"]
  use_median_of_three: true     # Essential for cable's variable latency

# Ping source IP (optional, default: OS routing table decides)
# Useful for multi-homed hosts to force pings out a specific interface.
# ping_source_ip: ""

# IRTT UDP RTT measurement (optional, disabled by default)
# Provides secondary RTT signal via UDP for dual-signal fusion
# irtt:
#   enabled: false
#   server: "your-irtt-server-ip"
#   port: 2112
#   duration_sec: 1.0
#   cadence_sec: 10

# Reflector quality scoring (optional, active when ping_hosts configured)
# Deprioritizes unreliable reflectors automatically
# reflector_quality:
#   min_score: 0.8
#   probe_interval_sec: 30
#   recovery_count: 3

# OWD asymmetry detection (optional, active when IRTT provides OWD data)
# Detects asymmetric congestion (upload-only or download-only bloat)
# owd_asymmetry:
#   ratio_threshold: 2.0          # OWD ratio above this flags asymmetry

# Dual-signal fusion (optional, disabled by default)
# Blends ICMP + IRTT RTT for more robust congestion detection
# Requires irtt.enabled: true to produce fused signal
# fusion:
#   enabled: false
#   icmp_weight: 0.7              # IRTT weight = 1.0 - icmp_weight
#   healing:
#     suspend_threshold: 0.3      # Correlation below this suspends fusion
#     recover_threshold: 0.5      # Correlation above this re-enables fusion
#     suspend_window_sec: 60.0    # Window to evaluate suspend condition
#     recover_window_sec: 300.0   # Window to evaluate recovery condition
#     grace_period_sec: 1800.0    # Cooldown after suspension before re-evaluation

# Adaptive tuning (optional, disabled by default)
# Analyzes metrics history to automatically optimize control parameters.
# All changes are runtime-only -- YAML values are always the reset escape hatch.
# tuning:
#   enabled: false
#   cadence_sec: 3600         # Analyze every hour (matches maintenance window)
#   lookback_hours: 24        # How far back to query metrics
#   warmup_hours: 1           # Minimum data before first tuning
#   max_step_pct: 10          # Max 10% change per tuning cycle
#   bounds:
#     target_bloat_ms: {min: 3, max: 30}
#     warn_bloat_ms: {min: 10, max: 100}
#     hard_red_bloat_ms: {min: 30, max: 200}
#     load_time_constant_sec: {min: 0.1, max: 10.0}
#     baseline_time_constant_sec: {min: 5.0, max: 500.0}

# Alerting (optional, requires Discord webhook)
# alerting:
#   enabled: false
#   webhook_url: "${DISCORD_WEBHOOK_URL}"  # From /etc/wanctl/secrets

# Storage retention (optional, defaults shown)
# Controls how long metrics data is kept at each granularity.
# storage:
#   retention:
#     raw_age_seconds: 3600              # Raw samples kept for 1 hour
#     aggregate_1m_age_seconds: 86400    # 1-minute aggregates kept for 24 hours
#     aggregate_5m_age_seconds: 604800   # 5-minute aggregates kept for 7 days
#     prometheus_compensated: false      # Set true if Prometheus scrapes metrics

logging:
  main_log: "/var/log/wanctl/cable.log"
  debug_log: "/var/log/wanctl/cable_debug.log"

lock_file: "/run/wanctl/cable.lock"
lock_timeout: 300

timeouts:
  ssh_command: 15
  ping: 1

state_file: "/var/lib/wanctl/cable_state.json"
