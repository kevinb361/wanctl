# Phase 200 saturation canary env template (VALN-06 deploy gate).
#
# Source this from the operator machine before running
# `scripts/phase200-saturation-canary.sh`.
#
# Current production values are comments only. They document the active
# deployment and are not defaults in the helper.

# Root directory for evidence. Recommended repo-local path:
# PHASE200_OUT_DIR=".planning/phases/200-per-direction-rtt-bloat-thresholds"
PHASE200_OUT_DIR=""

# Spectrum /health URL (HTTP 200 with .wans[0].upload structure expected).
# Current production: PHASE200_SPECTRUM_HEALTH_URL="http://10.10.110.223:9101/health"
PHASE200_SPECTRUM_HEALTH_URL=""

# iperf3 server target. Must be reachable from the local-bind IP via Spectrum egress.
# Example: PHASE200_IPERF_TARGET="104.200.21.31"
PHASE200_IPERF_TARGET=""

# Local source IP that exits Spectrum. Plan 06 verifies this with an egress probe.
# Example: PHASE200_IPERF_LOCAL_BIND="10.10.110.226"
PHASE200_IPERF_LOCAL_BIND=""

# Upload floor and ceiling, in Mbps, declared as the operator's expectation
# of /etc/wanctl/<wan>.yaml's continuous_monitoring.upload.{floor_mbps,
# ceiling_mbps}. /health does not expose these (it only carries runtime
# state), so they must be supplied explicitly per WAN.
#
# CRITICAL: these are an operator declaration, not a runtime read. The canary
# preflight cross-checks these against the deployed YAML via PHASE200_REMOTE_YAML_SSH
# below and ABORTs on any mismatch. Without this cross-check, stale env values
# would silently produce false-PASS verdicts because the floor-collapse selector
# compares current_rate_mbps against the wrong number.
#
# Current Spectrum production: floor_mbps=8, ceiling_mbps=18.
# Example: PHASE200_UL_FLOOR_MBPS=8
# Example: PHASE200_UL_CEILING_MBPS=18
PHASE200_UL_FLOOR_MBPS=""
PHASE200_UL_CEILING_MBPS=""

# user@host:/absolute/path/to/<wan>.yaml — preflight SSHes here, sudo-cats the
# YAML, parses continuous_monitoring.upload.{floor_mbps, ceiling_mbps}, and
# ABORTs if the values disagree with PHASE200_UL_FLOOR_MBPS /
# PHASE200_UL_CEILING_MBPS above. Operator's SSH must have sudo to read the
# protected /etc/wanctl/<wan>.yaml.
#
# The remote path component (after the first ':') must match this safe absolute
# path regex before any SSH command is constructed: ^/[A-Za-z0-9._/-]+$
# Example accepted: PHASE200_REMOTE_YAML_SSH="kevin@10.10.110.223:/etc/wanctl/spectrum.yaml"
# Example rejected: PHASE200_REMOTE_YAML_SSH="kevin@10.10.110.223:/etc/wanctl/spectrum.yaml; rm -rf /"
# Example: PHASE200_REMOTE_YAML_SSH="kevin@10.10.110.223:/etc/wanctl/spectrum.yaml"
PHASE200_REMOTE_YAML_SSH=""

# Phase 201 D-12 additions (env-declared expectation; canary preflight
# cross-checks against deployed YAML and ABORTs on mismatch). These also gate
# the /health DOCSIS-mode three-branch probe.
#
# Phase 201 runs are fail-closed: set these exactly to true/12 for the
# Spectrum DOCSIS deploy. Legacy A/B compatibility requires an explicit
# PHASE201_LEGACY_MODE=true opt-in instead; empty Phase 201 vars do NOT imply
# legacy mode.
#
# Example (Spectrum after Phase 201 deploy):
#   PHASE201_DOCSIS_MODE=true
#   PHASE201_SETPOINT_MBPS=12
PHASE201_DOCSIS_MODE=""
PHASE201_SETPOINT_MBPS=""
PHASE201_LEGACY_MODE=""

# Phase 201 (REVIEWS HIGH-5): cycle-fidelity floor-hit counter delta is the
# PRIMARY VALN-06 gate. The canary script reads
# /health.wans[0].upload.floor_hit_cycles_total at loaded-window start and end,
# and FAILS the canary if delta != 0 regardless of the 1 Hz snapshot-rate
# compare. No env var needed — the script reads /health directly.

# Optional overrides (defaults shown).
# PHASE200_LOAD_DURATION_SEC=900       # 15 minutes
# PHASE200_BASELINE_DURATION_SEC=60    # 60s pre + 60s post
# PHASE200_HEALTH_POLL_HZ=1            # 1 sample/sec
