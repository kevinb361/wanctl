#!/usr/bin/env bash
set -euo pipefail

CONF="${SILICOM_BYPASS_CONF:-/etc/silicom-bypass.conf}"
: "${BPCTL_UTIL:=/opt/bpctl-silicom/bpctl_util}"
: "${LOGGER:=logger}"
MARKS_LOG="${SILICOM_MARKS_LOG:-/var/log/silicom-bypass-marks.log}"
: "${SYSTEMCTL:=systemctl}"
: "${WD_ENV_DIR:=/etc/wanctl/bpctl-watchdog}"
: "${WD_RUN_DIR:=/run/wanctl/bpctl-watchdog}"

# shellcheck source=/dev/null
[ -r "$CONF" ] && . "$CONF"
: "${PAIRS:=att-modem spec-modem}"

usage() {
    cat <<'EOF'
Usage:
  silicom-bypass status [pair|all]
  silicom-bypass on <pair> --yes [--both-wan-confirm]
  silicom-bypass off <pair>
  silicom-bypass disc <pair> --yes [--both-wan-confirm]
  silicom-bypass conn <pair>
  silicom-bypass mark <label>
  silicom-bypass baseline
  silicom-bypass arm <pair> [timeout_ms] --yes
  silicom-bypass disarm <pair>

Exit codes: 0 ok/no-op, 1 runtime/read-back refusal, 2 usage.
EOF
}

die() {
    local message="$1" code="${2:-1}"
    printf 'silicom-bypass: %s\n' "$message" >&2
    exit "$code"
}

journal() {
    "$LOGGER" -t silicom-bypass -- "$*"
}

journal_best_effort() {
    journal "$*" || true
}

util() {
    local pair="$1"
    shift
    "$BPCTL_UTIL" "$pair" "$@"
}

pair_allowed() {
    local want="$1" pair
    for pair in $PAIRS; do
        [[ "$pair" == "$want" ]] && return 0
    done
    return 1
}

resolve_pair() {
    local pair="$1" slave
    pair_allowed "$pair" || die "unknown bypass pair '$pair' (configured PAIRS: $PAIRS)" 2
    if ! slave="$(util "$pair" get_bypass_slave 2>/dev/null)"; then
        die "$pair is not bypass-capable (get_bypass_slave failed)"
    fi
    [[ -n "$slave" ]] || die "$pair is not bypass-capable (empty get_bypass_slave)"
    printf '%s\n' "$pair"
}

other_pairs() {
    local current="$1" pair
    for pair in $PAIRS; do
        [[ "$pair" != "$current" ]] && printf '%s\n' "$pair"
    done
}

is_bypass_on_text() {
    local text="$1"
    case "$text" in
        *non-Bypass*) return 1 ;;
        *Bypass*) return 0 ;;
        *) return 1 ;;
    esac
}

is_disc_on_text() {
    local text="$1"
    case "$text" in
        *non-Disconnect*) return 1 ;;
        *Disconnect*) return 0 ;;
        *) return 1 ;;
    esac
}

assert_contains() {
    local got="$1" want="$2" context="$3"
    case "$got" in
        *"$want"*) return 0 ;;
        *) die "$context read-back failed: wanted '$want', got '$got'" ;;
    esac
}

matches_want() {
    local got="$1" want="$2"
    if [[ "$want" == "Bypass mode enabled" ]]; then
        case "$got" in
            *"Bypass mode enabled"*|*"Bypass mode is enabled"*) return 0 ;;
            *) return 1 ;;
        esac
    fi
    if [[ "$want" == "Bypass at power off" && "$got" == *"non-Bypass at power off"* ]]; then
        return 1
    fi
    if [[ "$want" == "Bypass at power off" ]]; then
        case "$got" in
            *"Bypass at power off"*|*"Bypass mode at power off state"*) return 0 ;;
            *) return 1 ;;
        esac
    fi
    if [[ "$want" == "non-Bypass at power up" ]]; then
        case "$got" in
            *"non-Bypass at power up"*|*"non-Bypass mode at power up state"*) return 0 ;;
            *) return 1 ;;
        esac
    fi
    if [[ "$want" == "non-Disconnect at power up" ]]; then
        case "$got" in
            *"non-Disconnect at power up"*|*"non-Disconnect mode at power up state"*) return 0 ;;
            *) return 1 ;;
        esac
    fi
    case "$got" in
        *"$want"*) return 0 ;;
        *) return 1 ;;
    esac
}

readiness_timeout_ms() {
    printf '%s\n' "${SILICOM_READY_TIMEOUT_MS:-5000}"
}

now_ms() {
    date +%s%3N
}

wait_bpctl_capable() {
    local pair="$1" timeout_ms deadline slave
    timeout_ms="$(readiness_timeout_ms)"
    deadline=$(( $(now_ms) + timeout_ms ))

    while :; do
        if slave="$(util "$pair" get_bypass_slave 2>/dev/null)" && [[ -n "$slave" ]]; then
            return 0
        fi
        if [[ "$(now_ms)" -ge "$deadline" ]]; then
            journal_best_effort "baseline $pair: never became bpctl-capable"
            die "$pair never became bpctl-capable before baseline"
        fi
        sleep 0.1
    done
}

read_back_failed() {
    local pair="$1" getverb="$2" want="$3" got="$4"
    journal_best_effort "baseline $pair $getverb: read-back FAILED (want '$want', got '$got')"
    die "$pair $getverb read-back FAILED (want '$want', got '$got')"
}

apply_assert() {
    local pair="$1" setverb="$2" setarg="$3" getverb="$4" want="$5" current got
    current="$(util "$pair" "$getverb")"
    if matches_want "$current" "$want"; then
        journal_best_effort "baseline $pair $getverb already matches '$want'; skip $setverb $setarg"
        return 0
    fi

    util "$pair" "$setverb" "$setarg"
    got="$(util "$pair" "$getverb")"
    if matches_want "$got" "$want"; then
            journal_best_effort "baseline $pair $setverb $setarg OK"
    else
        read_back_failed "$pair" "$getverb" "$want" "$got"
    fi
}

baseline_pair() {
    local pair="$1"
    wait_bpctl_capable "$pair"
    apply_assert "$pair" set_dis_bypass off get_dis_bypass "Bypass mode enabled"
    apply_assert "$pair" set_bypass_pwoff on get_bypass_pwoff "Bypass at power off"
    apply_assert "$pair" set_bypass_pwup off get_bypass_pwup "non-Bypass at power up"
    apply_assert "$pair" set_disc_pwup off get_disc_pwup "non-Disconnect at power up"
    apply_assert "$pair" set_std_nic off get_std_nic "not in Standard NIC mode"
}

assert_positive_bypass() {
    local got="$1" context="$2"
    is_bypass_on_text "$got" || die "$context read-back failed: wanted Bypass, got '$got'"
}

assert_positive_disc() {
    local got="$1" context="$2"
    is_disc_on_text "$got" || die "$context read-back failed: wanted Disconnect, got '$got'"
}

is_non_nic() {
    local pair bypass disc
    pair="$(resolve_pair "$1")"
    bypass="$(util "$pair" get_bypass)"
    disc="$(util "$pair" get_disc)"
    is_bypass_on_text "$bypass" || is_disc_on_text "$disc"
}

require_yes() {
    local yes="$1" verb="$2"
    [[ "$yes" == true ]] || die "$verb requires --yes"
}

check_both_wan_gate() {
    local pair="$1" confirmed="$2" other
    [[ "$confirmed" == true ]] && return 0
    while IFS= read -r other; do
        [[ -z "$other" ]] && continue
        if is_non_nic "$other"; then
            die "refusing: $pair and $other would both be non-NIC; pass --both-wan-confirm to proceed"
        fi
    done < <(other_pairs "$pair")
}

parse_flags() {
    YES=false
    BOTH_WAN_CONFIRM=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes) YES=true; shift ;;
            --both-wan-confirm) BOTH_WAN_CONFIRM=true; shift ;;
            --help|-h) usage; exit 0 ;;
            *) die "unknown argument: $1" 2 ;;
        esac
    done
}

pair_to_wd_instance() {
    case "$1" in
        att-modem) printf '%s\n' att ;;
        spec-modem) printf '%s\n' spectrum ;;
        *) die "no watchdog instance mapping for '$1'" 2 ;;
    esac
}

wd_env_path() {
    printf '%s/%s.env\n' "$WD_ENV_DIR" "$1"
}

wd_sentinel_path() {
    printf '%s/%s.disarm\n' "$WD_RUN_DIR" "$1"
}

validate_timeout_ms() {
    local value="$1"
    [[ "$value" =~ ^[1-9][0-9]*$ ]] || die "timeout must be > 0" 2
}

read_env_key() {
    local path="$1" key="$2"
    awk -F= -v key="$key" '$1 == key { value=$0; sub(/^[^=]*=/, "", value); print value; found=1 } END { if (!found) exit 1 }' "$path"
}

write_timeout_atomic() {
    local path="$1" timeout_ms="$2" tmp
    mkdir -p "$(dirname "$path")"
    tmp="$(mktemp "$(dirname "$path")/.${path##*/}.XXXXXX")"
    if [[ -f "$path" ]]; then
        awk -v timeout="$timeout_ms" '
          BEGIN { wrote=0 }
          /^TIMEOUT_MS=/ { print "TIMEOUT_MS=" timeout; wrote=1; next }
          { print }
          END { if (!wrote) print "TIMEOUT_MS=" timeout }
        ' "$path" > "$tmp"
    else
        printf 'TIMEOUT_MS=%s\n' "$timeout_ms" > "$tmp"
    fi
    chmod 0644 "$tmp"
    mv -f "$tmp" "$path"
}

validate_watchdog_env() {
    local path="$1" pair="$2" iface watched
    [[ -f "$path" ]] || die "env $path missing/invalid required keys (IFACE/WANCTL_UNIT)"
    iface="$(read_env_key "$path" IFACE || true)"
    watched="$(read_env_key "$path" WANCTL_UNIT || true)"
    [[ -n "$iface" && "$iface" == "$pair" && -n "$watched" ]] || \
        die "env $path missing/invalid required keys (IFACE/WANCTL_UNIT)"
    if [[ "$watched" == wanctl@* && "${WD_ALLOW_NATIVE_UNIT:-0}" != 1 ]]; then
        die "refusing to arm $pair: env WANCTL_UNIT names a native wanctl@ unit in cake mode (stale env); migrate the env first"
    fi
}

sentineled_stop() {
    (
        local iface="$1" unit sentinel rc active_rc
        shift
        [[ $# -ge 2 ]] || die "sentineled_stop requires a systemctl verb and unit" 2
        unit="${*: -1}"
        # wd_sentinel_path returns the fail-open operator sentinel: <iface>.disarm
        sentinel="$(wd_sentinel_path "$iface")"
        mkdir -p "$WD_RUN_DIR"
        trap 'rm -f "$sentinel"' EXIT
        : > "$sentinel"
        set +e
        "$SYSTEMCTL" "$@"
        rc=$?
        "$SYSTEMCTL" is-active --quiet "$unit"
        active_rc=$?
        set -e
        if [[ "$active_rc" -eq 0 ]]; then
            journal_best_effort "sentineled_stop $unit: unit still active after stop verb"
        else
            journal_best_effort "sentineled_stop $unit: unit inactive after stop verb"
        fi
        return "$rc"
    )
}

cmd_arm() {
    [[ $# -ge 1 ]] || die "arm requires a pair" 2
    local requested="$1" timeout_ms pair instance unit env_path active_rc state
    shift
    timeout_ms="${WD_TIMEOUT_MS:-10000}"
    if [[ $# -gt 0 && "$1" != --* ]]; then
        timeout_ms="$1"
        shift
    fi
    validate_timeout_ms "$timeout_ms"
    parse_flags "$@"
    require_yes "$YES" "arm"
    pair="$(resolve_pair "$requested")"
    instance="$(pair_to_wd_instance "$pair")"
    unit="silicom-bypass-watchdog@${instance}.service"
    env_path="$(wd_env_path "$instance")"

    if [[ "$instance" == att ]]; then
        state="$($SYSTEMCTL is-active silicom-bypass-watchdog-cake-autorate-att.service 2>/dev/null || true)"
        if [[ "$state" == active || "$state" == activating ]]; then
            die "refusing to arm @att while silicom-bypass-watchdog-cake-autorate-att.service is active (double-petter on att-modem); disable the retired variant first"
        fi
    fi

    validate_watchdog_env "$env_path" "$pair"
    write_timeout_atomic "$env_path" "$timeout_ms"
    validate_watchdog_env "$env_path" "$pair"

    set +e
    "$SYSTEMCTL" is-active --quiet "$unit"
    active_rc=$?
    set -e
    if [[ "$active_rc" -eq 0 ]]; then
        sentineled_stop "$pair" stop "$unit"
        "$SYSTEMCTL" enable "$unit"
        "$SYSTEMCTL" start "$unit"
        journal "arm $pair: wrote TIMEOUT_MS=$timeout_ms to $env_path (atomic); clean re-arm via sentineled_stop+start $unit"
    else
        "$SYSTEMCTL" enable "$unit"
        "$SYSTEMCTL" start "$unit"
        journal "arm $pair: wrote TIMEOUT_MS=$timeout_ms to $env_path (atomic); enabled+started $unit"
    fi
}

cmd_disarm() {
    [[ $# -eq 1 ]] || die "disarm requires exactly one pair" 2
    local pair instance unit cleanup_rc=0
    pair="$(resolve_pair "$1")"
    instance="$(pair_to_wd_instance "$pair")"
    unit="silicom-bypass-watchdog@${instance}.service"
    sentineled_stop "$pair" disable --now "$unit" || cleanup_rc=$?
    util "$pair" set_disc off || cleanup_rc=$?
    util "$pair" set_bypass off || cleanup_rc=$?
    util "$pair" set_bypass_wd 0 || cleanup_rc=$?
    if "$SYSTEMCTL" is-active --quiet "$unit"; then
        die "$unit still active after disarm"
    fi
    journal "disarm $pair: clean disarm via sentineled_stop — disabled $unit, restored inline (set_disc off/set_bypass off), cleared bypass_wd"
    return "$cleanup_rc"
}

cmd_status() {
    local target="${1:-all}" pair bypass disc std_nic
    [[ $# -le 1 ]] || die "status accepts at most one pair or all" 2
    if [[ "$target" == all ]]; then
        for pair in $PAIRS; do
            cmd_status "$pair"
        done
        return 0
    fi
    pair="$(resolve_pair "$target")"
    bypass="$(util "$pair" get_bypass)"
    disc="$(util "$pair" get_disc)"
    std_nic="$(util "$pair" get_std_nic)"
    printf '%s: bypass=%s disc=%s std_nic=%s\n' "$pair" "$bypass" "$disc" "$std_nic"
}

cmd_off() {
    [[ $# -eq 1 ]] || die "off requires exactly one pair" 2
    local pair cur got
    pair="$(resolve_pair "$1")"
    cur="$(util "$pair" get_bypass)"
    if ! is_bypass_on_text "$cur"; then
        printf '%s already non-bypass (NIC); no-op\n' "$pair"
        return 0
    fi
    util "$pair" set_bypass off
    got="$(util "$pair" get_bypass)"
    assert_contains "$got" "non-Bypass" "$pair set_bypass off"
    journal "off $pair: set_bypass off OK"
}

cmd_conn() {
    [[ $# -eq 1 ]] || die "conn requires exactly one pair" 2
    local pair cur got
    pair="$(resolve_pair "$1")"
    cur="$(util "$pair" get_disc)"
    if ! is_disc_on_text "$cur"; then
        printf '%s already non-disconnect (connected); no-op\n' "$pair"
        return 0
    fi
    util "$pair" set_disc off
    got="$(util "$pair" get_disc)"
    assert_contains "$got" "non-Disconnect" "$pair set_disc off"
    journal "conn $pair: set_disc off OK"
}

cmd_on() {
    [[ $# -ge 1 ]] || die "on requires a pair" 2
    local requested="$1" pair cur got
    shift
    parse_flags "$@"
    require_yes "$YES" "on"
    pair="$(resolve_pair "$requested")"
    cur="$(util "$pair" get_bypass)"
    if is_bypass_on_text "$cur"; then
        printf '%s already bypass; no-op\n' "$pair"
        return 0
    fi
    check_both_wan_gate "$pair" "$BOTH_WAN_CONFIRM"
    util "$pair" set_bypass on
    got="$(util "$pair" get_bypass)"
    assert_positive_bypass "$got" "$pair set_bypass on"
    journal "on $pair: set_bypass on OK"
}

cmd_disc() {
    [[ $# -ge 1 ]] || die "disc requires a pair" 2
    local requested="$1" pair cur got
    shift
    parse_flags "$@"
    require_yes "$YES" "disc"
    pair="$(resolve_pair "$requested")"
    cur="$(util "$pair" get_disc)"
    if is_disc_on_text "$cur"; then
        printf '%s already disconnect; no-op\n' "$pair"
        return 0
    fi
    check_both_wan_gate "$pair" "$BOTH_WAN_CONFIRM"
    util "$pair" set_disc on
    got="$(util "$pair" get_disc)"
    assert_positive_disc "$got" "$pair set_disc on"
    journal "disc $pair: set_disc on OK"
}

cmd_mark() {
    [[ $# -eq 1 ]] || die "mark requires exactly one label" 2
    local label="$1"
    journal "$label"
    mkdir -p "$(dirname "$MARKS_LOG")"
    printf '%s\n' "$label" >> "$MARKS_LOG"
    printf 'marked: %s\n' "$label"
}

cmd_baseline() {
    [[ $# -eq 0 ]] || die "baseline accepts no arguments" 2
    local pair
    for pair in $PAIRS; do
        baseline_pair "$pair"
    done
}

main() {
    [[ $# -ge 1 ]] || { usage >&2; exit 2; }
    local cmd="$1"
    shift
    case "$cmd" in
        status) cmd_status "$@" ;;
        off) cmd_off "$@" ;;
        conn) cmd_conn "$@" ;;
        on) cmd_on "$@" ;;
        disc) cmd_disc "$@" ;;
        mark) cmd_mark "$@" ;;
        baseline) cmd_baseline "$@" ;;
        arm) cmd_arm "$@" ;;
        disarm) cmd_disarm "$@" ;;
        --help|-h) usage ;;
        *) die "unknown subcommand: $cmd" 2 ;;
    esac
}

main "$@"
