# Phase 196 soak capture environment template.
#
# Source this from the operator machine before running
# `scripts/phase196-soak-capture.sh`.
#
# Current production values are comments only. They document the active
# deployment and are not defaults in the helper.

# Root directory for evidence. Recommended repo-local path:
# PHASE196_OUT_DIR=".planning/phases/196-spectrum-a-b-soak-and-att-regression-canary/soak"
PHASE196_OUT_DIR=""

# Spectrum evidence capture variables.
PHASE196_SPECTRUM_HEALTH_URL=""
# Current production: PHASE196_SPECTRUM_HEALTH_URL="http://10.10.110.223:9101/health"
PHASE196_SPECTRUM_SSH_HOST=""
# Current production: PHASE196_SPECTRUM_SSH_HOST="kevin@10.10.110.223"
PHASE196_SPECTRUM_METRICS_DB=""
# Current production: PHASE196_SPECTRUM_METRICS_DB="/var/lib/wanctl/metrics-spectrum.db"

# ATT evidence capture variables.
PHASE196_ATT_HEALTH_URL=""
# Current production: PHASE196_ATT_HEALTH_URL="http://10.10.110.227:9101/health"
PHASE196_ATT_SSH_HOST=""
# Current production: PHASE196_ATT_SSH_HOST="kevin@10.10.110.223"
PHASE196_ATT_METRICS_DB=""
# Current production: PHASE196_ATT_METRICS_DB="/var/lib/wanctl/metrics-att.db"
