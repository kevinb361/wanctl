# Phase 192 soak capture - required environment variables.
#
# Source a filled-in copy of this file before running:
#   scripts/phase192-soak-capture.sh pre
#   scripts/phase192-soak-capture.sh post
#
# Production values are listed as comments only. They are not defaults in the
# script itself, per the portable-controller rule in CLAUDE.md / AGENTS.md.

# Space-separated WAN names. These must match the wanctl@${wan}.service unit names.
WANS=""
# Current production: WANS="spectrum att"

# Per-WAN /health URLs reachable from the machine running the capture.
WANCTL_SPECTRUM_HEALTH_URL=""
# Current production: WANCTL_SPECTRUM_HEALTH_URL="http://10.10.110.223:9101/health"
WANCTL_ATT_HEALTH_URL=""
# Current production: WANCTL_ATT_HEALTH_URL="http://10.10.110.227:9101/health"

# Per-WAN SSH targets for the journal source host(s).
WANCTL_SPECTRUM_SSH_HOST=""
# Current production: WANCTL_SPECTRUM_SSH_HOST="10.10.110.223"
WANCTL_ATT_SSH_HOST=""
# Current production: WANCTL_ATT_SSH_HOST="10.10.110.223"
