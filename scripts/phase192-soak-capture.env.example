# Phase 192 soak capture environment template.
#
# Source this from the operator machine before running
# `scripts/phase192-soak-capture.sh`.
#
# The current production values below are comments only. They are examples for
# the active deployment, not defaults in the script.

# Space-separated WAN names. These should match the `wanctl@<wan>` service
# suffixes used in production.
WANS=""
# Current production: WANS="spectrum att"

# Per-WAN health endpoint URLs.
WANCTL_SPECTRUM_HEALTH_URL=""
# Current production: WANCTL_SPECTRUM_HEALTH_URL="http://10.10.110.223:9101/health"
WANCTL_ATT_HEALTH_URL=""
# Current production: WANCTL_ATT_HEALTH_URL="http://10.10.110.227:9101/health"

# Per-WAN SSH targets for journalctl reads. Multiple WANs may share a host.
WANCTL_SPECTRUM_SSH_HOST=""
# Current production: WANCTL_SPECTRUM_SSH_HOST="kevin@10.10.110.223"
WANCTL_ATT_SSH_HOST=""
# Current production: WANCTL_ATT_SSH_HOST="kevin@10.10.110.223"
